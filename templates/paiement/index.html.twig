{% extends 'base.html.twig' %}

{% block title %}Paiement — Cabinet Martin{% endblock %}

{% block main %}
<section class="section">
  <div class="container" data-aos="fade-up">

    <div class="section-title">
      <h2>Paiement</h2>
      <p>Finalisez votre commande en toute securite</p>
    </div>

    {% for label, messages in app.flashes %}
      {% for m in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show">
          {{ m }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
    {% endfor %}

    <div class="row g-4 justify-content-center">
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2 text-primary"></i>Informations de paiement</h5>
          </div>
          <div class="card-body p-4">

            <form method="post" action="{{ path('app_paiement_payer') }}">

              <div class="mb-3">
                <label class="form-label fw-semibold">Nom du titulaire</label>
                <input type="text" name="nom" class="form-control form-control-lg"
                  placeholder="Jean Martin" required>
              </div>

              <div class="mb-3">
                <label class="form-label fw-semibold">Numero de carte</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-credit-card-2-front"></i></span>
                  <input type="text" name="numero" class="form-control form-control-lg"
                    placeholder="0000 0000 0000 0000" maxlength="19" required>
                </div>
              </div>

              <div class="row g-3 mb-4">
                <div class="col-7">
                  <label class="form-label fw-semibold">Date d'expiration</label>
                  <input type="text" name="expiration" class="form-control form-control-lg"
                    placeholder="MM/AA" maxlength="5" required>
                </div>
                <div class="col-5">
                  <label class="form-label fw-semibold">CVV</label>
                  <div class="input-group">
                    <input type="text" name="cvv" class="form-control form-control-lg"
                      placeholder="123" maxlength="4" required>
                    <span class="input-group-text" data-bs-toggle="tooltip" title="3 chiffres au dos de votre carte">
                      <i class="bi bi-question-circle"></i>
                    </span>
                  </div>
                </div>
              </div>

              <div class="alert alert-light border d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-shield-lock-fill text-success fs-5"></i>
                <small class="text-muted">Paiement securise. Vos donnees bancaires ne sont pas stockees.</small>
              </div>

              <div class="d-grid">
                <button class="btn btn-primary btn-lg" type="submit">
                  <i class="bi bi-lock me-2"></i>Confirmer et payer
                </button>
              </div>

            </form>
          </div>
        </div>
      </div>

      {# Recapitulatif commande #}
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-bag me-2 text-primary"></i>Votre commande</h5>
          </div>
          <div class="card-body">
            {% for item in items %}
              <div class="d-flex justify-content-between small mb-2">
                <span class="text-muted">{{ item.nom }} x{{ item.quantite }}</span>
                <strong>{{ (item.prix * item.quantite)|number_format(2, '.', ',') }} €</strong>
              </div>
            {% endfor %}
            <hr>
            <div class="d-flex justify-content-between fw-bold">
              <span>Total</span>
              <span class="text-primary fs-5">{{ total|number_format(2, '.', ',') }} €</span>
            </div>
          </div>
          <div class="card-footer bg-white border-0">
            <a href="{{ path('app_panier') }}" class="btn btn-sm btn-outline-secondary w-100">
              <i class="bi bi-arrow-left me-1"></i>Modifier le panier
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
{% endblock %}
