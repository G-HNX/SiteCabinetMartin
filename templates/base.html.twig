  <link href="{{ asset('/css/main.css') }}" rel="stylesheet">

  <style>
    /* ── Panier badge dans la nav ── */
    .nav-cart-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
    }
    .nav-cart-badge {
      position: absolute;
      top: -6px; right: -8px;
      background: #e63946;
      color: #fff;
      border-radius: 10px;
      font-size: .6rem;
      font-weight: 700;
      min-width: 16px;
      height: 16px;
      line-height: 16px;
      text-align: center;
      padding: 0 4px;
      pointer-events: none;
    }

    /* ── Chip utilisateur connecté ── */
    .nav-user-chip {
      display: inline-flex !important;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,.15);
      border-radius: 20px;
      padding: 4px 12px !important;
      font-size: .82rem !important;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,.25);
    }
    .nav-user-chip:hover {
      background: rgba(255,255,255,.25) !important;
    }

    /* ── Icône déconnexion ── */
    .nav-logout-link {
      opacity: .75;
      font-size: 1.1rem !important;
      padding: 0 6px !important;
    }
    .nav-logout-link:hover { opacity: 1; }

    /* ── Séparateur dans les dropdowns ── */
    .dropdown-divider {
      margin: 4px 12px;
      border-color: rgba(0,0,0,.08);
    }

    /* ── Icônes dans les items de dropdown ── */
    #navmenu .dropdown ul a i {
      font-size: .85rem;
      opacity: .7;
    }

    /* ── Séparateur vertical entre nav et compte ── */
    #navmenu ul li.nav-sep {
      display: flex;
      align-items: center;
      padding: 0 10px;
      pointer-events: none;
    }
    #navmenu ul li.nav-sep::after {
      content: '';
      display: block;
      width: 1px;
      height: 20px;
      background: #d0d8e4;
    }

    /* ── Encadré compte ── */
    #navmenu ul li.nav-account > a {
      border: 1.5px solid #b0bece !important;
      border-radius: 8px !important;
      padding: 5px 14px !important;
      margin-left: 4px;
      transition: background .2s, border-color .2s, color .2s !important;
    }
    #navmenu ul li.nav-account > a:hover,
    #navmenu ul li.nav-account > a.active {
      background: #f0f5fb !important;
      border-color: #2aa4b5 !important;
      color: #2aa4b5 !important;
    }

    /* Mobile : on retire l'encadré */
    @media (max-width: 1199px) {
      #navmenu ul li.nav-sep { display: none !important; }
      #navmenu ul li.nav-account > a {
        border: none !important;
        border-radius: 0 !important;
        margin-left: 0;
        padding: 10px 20px !important;
      }
    }
  </style>

  <!-- =======================================================
  * Template Name: Medilab
  * Template URL: https://bootstrapmade.com/medilab-free-medical-bootstrap-theme/
