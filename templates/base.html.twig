  ======================================================== -->
</head>
    <body class="index-page">
        {% set current = app.request.attributes.get('_route') %}
        {% set cartCount = app.request.session.get('count', 0) %}

        <!-- Entete -->
        <header id="header" class="header sticky-top">

            <!-- Topbar -->
            <div class="topbar d-flex align-items-center">
                <div class="container d-flex justify-content-center justify-content-md-between">
                    <div class="contact-info d-flex align-items-center">
                        <i class="bi bi-envelope d-flex align-items-center">
                            <a href="mailto:cabinetmartinonline535@gmail.com">cabinetmartinonline535@gmail.com</a>
                        </i>
                        <i class="bi bi-phone d-flex align-items-center ms-4">
                            <span>02 99 99 99 99</span>
                        </i>
                        <i class="bi bi-clock d-none d-lg-flex align-items-center ms-4">
                            <span>Lun–Ven 8h–18h &nbsp;&bull;&nbsp; Sam 8h–12h</span>
                        </i>
                    </div>
                    <div class="social-links d-none d-md-flex align-items-center">
                        <a href="#" class="twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="linkedin"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div><!-- End Topbar -->

            <!-- Branding + Nav -->
            <div class="branding d-flex align-items-center">
                <div class="container position-relative d-flex align-items-center justify-content-between">

                    <a href="{{ path('app_home') }}" class="logo d-flex align-items-center me-auto">
                        <h1 class="sitename">Cabinet Martin</h1>
                    </a>

                    <nav id="navmenu" class="navmenu">
                        {% set cabinetActive = current in ['app_about', 'app_medecin'] %}
                        {% set servicesActive = (current starts with 'app_pharmacie') or current == 'app_teleconsultation' %}
                        {% set compteActive = current in ['app_profil', 'app_facture'] %}
                        <ul>

                            <!-- Accueil -->
                            <li>
                                <a href="{{ path('app_home') }}" class="{{ current == 'app_home' ? 'active' : '' }}">Accueil</a>
                            </li>

                            <!-- Le Cabinet -->
                            <li class="dropdown">
                                <a href="#" class="{{ cabinetActive ? 'active' : '' }}">
                                    <span>Le Cabinet</span>
                                    <i class="bi bi-chevron-down toggle-dropdown"></i>
                                </a>
                                <ul>
                                    <li>
                                        <a href="{{ path('app_about') }}" class="{{ current == 'app_about' ? 'active' : '' }}">
                                            <i class="bi bi-info-circle me-2"></i>A propos
                                        </a>
                                    </li>
                                    <li>
                                        <a href="{{ path('app_medecin') }}" class="{{ current == 'app_medecin' ? 'active' : '' }}">
                                            <i class="bi bi-person-badge me-2"></i>Nos medecins
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Services -->
                            <li class="dropdown">
                                <a href="#" class="{{ servicesActive ? 'active' : '' }}">
                                    <span>Services</span>
                                    <i class="bi bi-chevron-down toggle-dropdown"></i>
                                </a>
                                <ul>
                                    <li>
                                        <a href="{{ path('app_pharmacie') }}" class="{{ (current starts with 'app_pharmacie') ? 'active' : '' }}">
                                            <i class="bi bi-capsule me-2"></i>Pharmacie en ligne
                                        </a>
                                    </li>
                                    <li>
                                        <a href="{{ path('app_teleconsultation') }}" class="{{ current == 'app_teleconsultation' ? 'active' : '' }}">
                                            <i class="bi bi-camera-video me-2"></i>Teleconsultation
                                        </a>
                                    </li>
                                    <li>
                                        <a href="{{ path('app_rendez_vous') }}" class="{{ current == 'app_rendez_vous' ? 'active' : '' }}">
                                            <i class="bi bi-calendar-check me-2"></i>Prendre un RDV
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Contact -->
                            <li>
                                <a href="{{ path('app_contact') }}" class="{{ current == 'app_contact' ? 'active' : '' }}">Contact</a>
                            </li>

                            <!-- Séparateur -->
                            <li class="nav-sep d-none d-xl-flex"></li>

                            <!-- Mon compte -->
                            {% if app.user %}
                                <li class="dropdown nav-account">
                                    <a href="#" class="{{ compteActive ? 'active' : '' }}">
                                        <span class="nav-user-chip">
                                            <i class="bi bi-person-circle"></i>
                                            {{ app.user.getPersonne().getPrenom() ?? app.user.email }}
                                        </span>
                                        <i class="bi bi-chevron-down toggle-dropdown"></i>
                                    </a>
                                    <ul>
                                        <li>
                                            <a href="{{ path('app_profil') }}" class="{{ current == 'app_profil' ? 'active' : '' }}">
                                                <i class="bi bi-person me-2"></i>Mon profil
                                            </a>
                                        </li>
                                        <li>
                                            <a href="{{ path('app_facture') }}" class="{{ current == 'app_facture' ? 'active' : '' }}">
                                                <i class="bi bi-receipt me-2"></i>Mes factures
                                            </a>
                                        </li>
                                        <li>
                                            <a href="{{ path('app_rendez_vous') }}" class="{{ current == 'app_rendez_vous' ? 'active' : '' }}">
                                                <i class="bi bi-calendar me-2"></i>Mes rendez-vous
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a href="{{ path('app_logout') }}">
                                                <i class="bi bi-box-arrow-right me-2"></i>Deconnexion
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            {% else %}
                                <li class="nav-account">
                                    <a href="{{ path('app_login') }}" class="{{ current == 'app_login' ? 'active' : '' }}">
                                        <i class="bi bi-person me-1"></i>Connexion
                                    </a>
                                </li>
                            {% endif %}

                        </ul>
                        <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
                    </nav>

                    <a class="cta-btn d-none d-sm-block" href="{{ path('app_panier') }}" title="Mon panier">
                        <span class="nav-cart-wrap">
                            <i class="bi bi-cart3"></i>
                            {% if cartCount > 0 %}
                                <span class="nav-cart-badge">{{ cartCount }}</span>
                            {% endif %}
                        </span>
                    </a>

                </div>
            </div><!-- End Branding -->

        </header>

        <main>
        {% block main %} {% endblock %}
        </main>
        
        <!-- pied de page-->
        <footer id="footer" class="footer light-background">

        <div class="container footer-top">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-6 footer-about">
                <a href="{{path('app_home')}}" class="logo d-flex align-items-center">
                    <span class="sitename">Cabinet Médical</span>
                </a>
                <div class="footer-contact pt-3">
                    <p>7, rue des Archives</p>
                    <p>53 000 Laval</p>
                    <p class="mt-3"><strong>Phone:</strong> <span>02 99 99 99 99</span></p>
                    <p><strong>Email:</strong> <span>cabinetmartinonline535@gmail.com</span></p>
                </div>
                <div class="social-links d-flex mt-4">
                    <a href=""><i class="bi bi-twitter-x"></i></a>
                    <a href=""><i class="bi bi-facebook"></i></a>
                    <a href=""><i class="bi bi-instagram"></i></a>
                    <a href=""><i class="bi bi-linkedin"></i></a>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 footer-links">                
                <ul>
                    <li><a href="{{path('app_home')}}">Home</a></li>
                    <li><a href="{{path('app_about')}}">About us</a></li>                
                    <li><a href="{{path('app_politique')}}">Privacy policy</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-md-4 footer-links">                
                <ul>
                    <li><a href="#">Services</a></li>
                    <li><a href="{{path('app_medecin')}}">Médecins</a></li>                
                    
                </ul>
            </div>
            <div class="col-lg-2 col-md-4 footer-links">                
                <ul>
                    <li><a href="{{ path('app_login') }}">Connexion</a></li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
            </div>

        </div>
        </div>

        <div class="container copyright text-center mt-4">
            <p>© <span>Copyright</span> <strong class="px-1 sitename">Cabinet Martin</strong> <span>All Rights Reserved</span></p>
        </div>
    </footer>

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    


  <!-- Vendor JS Files -->
  <script src="{{ asset('/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
  <script src="{{ asset('/vendor/php-email-form/validate.js') }}"></script>
  <script src="{{ asset('/vendor/aos/aos.js') }}"></script>
  <script src="{{ asset('/vendor/glightbox/js/glightbox.min.js') }}"></script>
  <script src="{{ asset('/vendor/purecounter/purecounter_vanilla.js') }}"></script>
  <script src="{{ asset('/vendor/swiper/swiper-bundle.min.js') }}"></script>

  <!-- Main JS File -->
  <script src="{{ asset('/js/main.js') }}"></script>

  {% block javascripts %}{% endblock %}
    </body>
</html>
