<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:40px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 2px 20px rgba(0,0,0,.08);">

        <!-- Header -->
        <tr>
          <td style="background:#1a3c5e;padding:32px 40px;text-align:center;">
            <h1 style="margin:0;color:#fff;font-size:24px;font-weight:800;">
              Cabinet <span style="color:#2aa4b5;">Martin</span>
            </h1>
            <p style="margin:6px 0 0;color:#b8cfe0;font-size:13px;">7, rue des Archives — 53 000 Laval</p>
          </td>
        </tr>

        <!-- Bannière -->
        <tr>
          <td style="background:#2aa4b5;padding:24px;text-align:center;">
            <p style="margin:0;color:#fff;font-size:32px;">✓</p>
            <p style="margin:8px 0 0;color:#fff;font-size:16px;font-weight:bold;">Commande confirmée</p>
          </td>
        </tr>

        <!-- Corps -->
        <tr>
          <td style="padding:40px;">
            <p style="margin:0 0 16px;color:#2c2c2c;font-size:15px;line-height:1.6;">
              Bonjour <strong>{{ commande.personne.prenom }} {{ commande.personne.nom }}</strong>,
            </p>
            <p style="margin:0 0 28px;color:#2c2c2c;font-size:15px;line-height:1.6;">
              Votre commande <strong>#{{ commande.id }}</strong> du <strong>{{ commande.dateCommande|date('d/m/Y à H:i') }}</strong>
              a bien été enregistrée et est en cours de préparation.
            </p>

            <!-- Tableau des articles -->
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;border-collapse:collapse;">
              <tr style="background:#1a3c5e;color:#fff;">
                <td style="padding:10px 14px;font-size:12px;text-transform:uppercase;letter-spacing:.5px;">Médicament</td>
                <td style="padding:10px 14px;font-size:12px;text-transform:uppercase;letter-spacing:.5px;text-align:center;">Qté</td>
                <td style="padding:10px 14px;font-size:12px;text-transform:uppercase;letter-spacing:.5px;text-align:right;">Sous-total</td>
              </tr>
              {% set total = 0 %}
              {% for ligne in commande.lignesCommande %}
                {% set sous_total = ligne.prix * ligne.quantite %}
                {% set total = total + sous_total %}
                <tr style="border-bottom:1px solid #eef1f5;">
                  <td style="padding:10px 14px;color:#2c2c2c;font-size:14px;">
                    {{ ligne.medicamentLigneCommande ? ligne.medicamentLigneCommande.nom : 'Article' }}
                  </td>
                  <td style="padding:10px 14px;text-align:center;color:#666;font-size:14px;">{{ ligne.quantite }}</td>
                  <td style="padding:10px 14px;text-align:right;font-weight:bold;font-size:14px;">{{ sous_total|number_format(2, ',', ' ') }} €</td>
                </tr>
              {% endfor %}
              <!-- Total -->
              <tr style="background:#f4f7fb;">
                <td colspan="2" style="padding:12px 14px;text-align:right;font-weight:bold;color:#1a3c5e;">Total TTC</td>
                <td style="padding:12px 14px;text-align:right;font-weight:bold;font-size:16px;color:#2aa4b5;">{{ total|number_format(2, ',', ' ') }} €</td>
              </tr>
            </table>

            <p style="margin:0;color:#666;font-size:13px;line-height:1.6;">
              Vous pouvez retrouver cette facture dans votre espace personnel.
            </p>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#f4f7fb;padding:24px 40px;text-align:center;border-top:1px solid #eee;">
            <p style="margin:0;color:#aaa;font-size:11px;">
              Cabinet Martin &mdash; 02 99 99 99 99 &mdash; cabinetmartinonline535@gmail.com
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>

</body>
</html>
