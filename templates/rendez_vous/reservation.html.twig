{% extends 'base.html.twig' %}

{% block title %}Réservation — Cabinet Martin{% endblock %}

{% block main %}
  <style>
    .example-wrapper {
      margin: 1em auto;
      max-width: 800px;
      width: 95%;
      font: 18px/1.5 sans-serif;
    }

    .example-wrapper code {
      background: #F5F5F5;
      padding: 2px 6px;
    }

    .availability-table .btn {
      min-width: 64px;
    }
  </style>

  <div class="example-wrapper">
    <h1>Votre réservation</h1>

    <div class="container py-4">
      {# Flash messages (réservation etc.) #}
      {% for label, messages in app.flashes %}
        {% for m in messages %}
          <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show" role="alert">
            {{ m }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        {% endfor %}
      {% endfor %}

      {#
        Insérer le formulaire ici pour réserver un slot avec un motif et un bouton
        pour savoir si le client souhaite la téléconsultation.
        Le patient doit être connecté.
      #}

      <p>
        {{ doctor }} — {{ slot }}
      </p>
    </div>
  </div>

{% endblock %}