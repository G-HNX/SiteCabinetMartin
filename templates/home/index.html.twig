          <div class="faq-item">
            <h3>Proposez-vous la téléconsultation ?</h3>
            <div class="faq-content">
              <p>Oui, vous pouvez prendre un rendez-vous en ligne ou contactez le secrétariat.</p>
            </div>
            <i class="faq-toggle bi bi-chevron-right"></i>
          </div>
          <div class="faq-item">
            <h3>Quels sont les délais pour un rendez-vous ?</h3>
            <div class="faq-content">
              <p>La plupart des motifs obtiennent un créneau sous quelques jours. Urgences : appelez.</p>
            </div>
            <i class="faq-toggle bi bi-chevron-right"></i>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>


<section id="contact" class="contact section">
  <div class="container section-title">
    <h2>L'accès au cabinet médical</h2>
    <p>Adresse, téléphone et Plan.</p>
  </div>

  

  <div class="container" >
    <div class="row gy-4">
      <div class="col-lg-4">
        <div class="info-item d-flex">
          <i class="bi bi-geo-alt flex-shrink-0"></i>
          <div>
            <h3>Adresse</h3>
            <p>7, rue des archives / 53000 / Laval</p>
          </div>
        </div>

        <div class="info-item d-flex" >
          <i class="bi bi-telephone flex-shrink-0"></i>
          <div>
            <h3>Téléphone</h3>
            <p>02 99 99 99 99</p>
          </div>
        </div>

        <div class="info-item d-flex" >
          <i class="bi bi-envelope flex-shrink-0"></i>
          <div>
            <h3>Email</h3>
            <p>cabinetmartinoneline535gmail.com</p>
          </div>
        </div>
      </div>

      <div class="col-lg-8" id="gmap">
        
    
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2665.986843668288!2d-0.7633576883544411!3d48.0718968556119!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4808fdfbc1fa6b87%3A0x1cca4f4697d0baa6!2sCabinetMartinA%2C%207%20Rue%20des%20Archives%2C%2053000%20Laval!5e0!3m2!1sfr!2sfr!4v1761783470134!5m2!1sfr!2sfr" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
  
      </div> 
    </div>
  </div>
</section>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.querySelector('.faq-container') || document;

  // Init accessibilité + état affiché/masqué
  document.querySelectorAll('.faq-item').forEach(el => {
    const h3 = el.querySelector('h3');
    const content = el.querySelector('.faq-content');

    if (h3) {
      h3.setAttribute('role', 'button');
      h3.setAttribute('tabindex', '0');
      h3.setAttribute('aria-expanded', el.classList.contains('faq-active') ? 'true' : 'false');
    }
    if (content) {
      content.hidden = !el.classList.contains('faq-active');
    }
  });

  function activate(item) {
    document.querySelectorAll('.faq-item').forEach(el => {
      const isActive = el === item;
      el.classList.toggle('faq-active', isActive);

      const h3 = el.querySelector('h3');
      const content = el.querySelector('.faq-content');
      if (h3) h3.setAttribute('aria-expanded', isActive ? 'true' : 'false');
      if (content) content.hidden = !isActive;
    });
  }

  // Clic sur l’item (ou un enfant)
  container.addEventListener('click', (e) => {
    const item = e.target.closest('.faq-item');
    if (!item) return;
    activate(item);
  });

  // Clavier sur le titre
  container.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const h3 = e.target.closest('.faq-item h3');
    if (!h3) return;
    e.preventDefault();
    activate(h3.closest('.faq-item'));
  });
});

var iframe = document.getElementById('gmap');
iframe.addEventListener('load', () => {
    alert('ok');
    document.querySelector('.place-name').textContent = 'Cabinet Martin';
    
  });
    
</script>
{% endblock %}
