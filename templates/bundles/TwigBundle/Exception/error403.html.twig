{% extends 'base.html.twig' %}

{% block title %}Accès refusé — Cabinet Martin{% endblock %}

{% block main %}
<section class="section">
  <div class="container text-center" data-aos="fade-up" style="padding: 80px 0;">

    <div style="font-size: 7rem; line-height: 1; color: #e63946; font-weight: 800; letter-spacing: -4px;">
      403
    </div>

    <div class="mb-4" style="font-size: 4rem;">
      <i class="bi bi-shield-lock" style="color: #1a3c5e; opacity: .15;"></i>
    </div>

    <h1 class="fw-bold mb-3" style="color: #1a3c5e;">Acces refuse</h1>
    <p class="text-muted mb-5" style="max-width: 480px; margin: 0 auto 2rem;">
      Vous n'avez pas les droits necessaires pour acceder a cette page.
      Connectez-vous ou revenez a l'accueil.
    </p>

    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg px-4">
        <i class="bi bi-person me-2"></i>Se connecter
      </a>
      <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg px-4">
        <i class="bi bi-house me-2"></i>Retour a l'accueil
      </a>
    </div>

  </div>
</section>
{% endblock %}
