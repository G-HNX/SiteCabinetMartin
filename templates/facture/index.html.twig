{% extends 'base.html.twig' %}

{% block title %}Mes factures — Cabinet Martin{% endblock %}

{% block main %}
<section class="section">
  <div class="container" data-aos="fade-up">

    <div class="section-title">
      <h2>Mes factures</h2>
      <p>Historique de toutes vos commandes</p>
    </div>

    {% for label, messages in app.flashes %}
      {% for m in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show">
          {{ m }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
    {% endfor %}

    {% if commandes is empty %}
      <div class="text-center py-5">
        <i class="bi bi-receipt text-muted" style="font-size: 5rem;"></i>
        <h4 class="mt-3 text-muted">Aucune facture disponible</h4>
        <a href="{{ path('app_pharmacie') }}" class="btn btn-primary mt-3">
          <i class="bi bi-capsule me-2"></i>Aller a la pharmacie
        </a>
      </div>

    {% else %}
      {% for commande in commandes %}
        {% set total = 0 %}
        {% for ligne in commande.lignesCommande %}
          {% set total = total + (ligne.prix * ligne.quantite) %}
        {% endfor %}

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <div>
              <span class="fw-bold">Commande #{{ commande.id }}</span>
              <span class="text-muted ms-3 small">{{ commande.dateCommande|date('d/m/Y a H:i') }}</span>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="badge bg-success">Payee</span>
              <a href="{{ path('app_facture_pdf', {id: commande.id}) }}"
                 class="btn btn-sm btn-outline-primary"
                 title="Telecharger la facture PDF">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
              </a>
            </div>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Medicament</th>
                    <th class="text-center">Quantite</th>
                    <th class="text-end">Prix unitaire</th>
                    <th class="text-end">Sous-total</th>
                  </tr>
                </thead>
                <tbody>
                  {% for ligne in commande.lignesCommande %}
                    <tr>
                      <td>
                        <strong>{{ ligne.medicamentLigneCommande ? ligne.medicamentLigneCommande.nom : 'Article supprime' }}</strong>
                      </td>
                      <td class="text-center">{{ ligne.quantite }}</td>
                      <td class="text-end">{{ ligne.prix }} €</td>
                      <td class="text-end fw-semibold">{{ (ligne.prix * ligne.quantite)|number_format(2, '.', ',') }} €</td>
                    </tr>
                  {% endfor %}
                </tbody>
                <tfoot>
                  <tr class="table-light">
                    <td colspan="3" class="text-end fw-bold">Total</td>
                    <td class="text-end fw-bold text-primary">{{ total|number_format(2, '.', ',') }} €</td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}

  </div>
</section>
{% endblock %}
