{% extends 'base.html.twig' %}

{% block title %}{{ product.nom }} — Pharmacie Cabinet Martin{% endblock %}

{% block main %}
<section class="section">
  <div class="container" data-aos="fade-up">

    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_pharmacie') }}">Pharmacie</a></li>
        <li class="breadcrumb-item">
          <a href="{{ path('app_pharmacie_cat', {cat: cat}) }}">{{ categories[cat-1].nom }}</a>
        </li>
        <li class="breadcrumb-item active">{{ product.nom }}</li>
      </ol>
    </nav>

    {% for label, messages in app.flashes %}
      {% for m in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show">
          {{ m }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
    {% endfor %}

    <div class="row g-5">

      <div class="col-md-5 text-center">
        <img src="{{ asset(product.image) }}" alt="{{ product.nom }}"
          class="img-fluid rounded shadow" style="max-height: 350px; object-fit: contain;">
      </div>

      <div class="col-md-7">
        <span class="badge bg-primary mb-2">{{ categories[cat-1].nom }}</span>
        <h1 class="fw-bold mb-2">{{ product.nom }}</h1>

        <div class="d-flex align-items-center gap-3 mb-3">
          <span class="fs-2 fw-bold text-primary">{{ product.prix }} €</span>
          {% if product.stock > 10 %}
            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>En stock</span>
          {% elseif product.stock > 0 %}
            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-circle me-1"></i>Stock faible ({{ product.stock }} restants)</span>
          {% else %}
            <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rupture de stock</span>
          {% endif %}
        </div>

        <div class="row g-3 mb-4">
          <div class="col-6">
            <div class="card border-0 bg-light p-3 text-center">
              <small class="text-muted">Forme</small>
              <strong>{{ product.forme }}</strong>
            </div>
          </div>
          <div class="col-6">
            <div class="card border-0 bg-light p-3 text-center">
              <small class="text-muted">Dosage</small>
              <strong>{{ product.dosage }} mg</strong>
            </div>
          </div>
        </div>

        <p class="text-muted mb-4">{{ product.description }}</p>

        {% if product.stock > 0 %}
          <form method="post" action="{{ path('app_panier_add', {id: product.id}) }}" class="d-flex align-items-center gap-3">
            <div class="input-group" style="width: 130px;">
              <span class="input-group-text">Qte</span>
              <input type="number" name="quantite" value="1" min="1" max="{{ product.stock }}"
                class="form-control text-center">
            </div>
            <button type="submit" class="btn btn-primary btn-lg">
              <i class="bi bi-cart-plus me-2"></i>Ajouter au panier
            </button>
          </form>
        {% else %}
          <button class="btn btn-secondary btn-lg" disabled>
            <i class="bi bi-x-circle me-2"></i>Rupture de stock
          </button>
        {% endif %}

      </div>
    </div>

    <div class="mt-5">
      <a href="{{ path('app_pharmacie_cat', {cat: cat}) }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Retour a la categorie
      </a>
    </div>

  </div>
</section>
{% endblock %}
