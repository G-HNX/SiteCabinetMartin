{% extends 'base.html.twig' %}

{% block title %}Nos médécins{% endblock %}

{% block main %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Nos médecins</h1>

    
{# === Doctors ============================================================ #}
<section id="doctors" class="doctors section">
  <div class="container section-title" >
    <h2>Équipe médicale</h2>
    <p>Des compétences complémentaires pour une prise en charge globale.</p>
  </div>

  <div class="container">
    <div class="row gy-4">

      <div class="col-lg-6" >
        <div class="team-member d-flex align-items-start">
          <div class="pic"><img src="{{ asset('img/doctors/doctors-1.jpg') }}" class="img-fluid" alt="Dr Martin"></div>
          <div class="member-info">
            <h4>Dr Martin</h4>
            <span>Médecine interne</span>
            <p>Suivi des maladies chroniques, diagnostics complexes, coordination pluridisciplinaire.</p>
          </div>
        </div>
      </div>

      <div class="col-lg-6" >
        <div class="team-member d-flex align-items-start">
          <div class="pic"><img src="{{ asset('img/doctors/doctors-3.jpg') }}" class="img-fluid" alt="Dr House"></div>
          <div class="member-info">
            <h4>Dr House</h4>
            <span>Médecine générale</span>
            <p>Consultations du quotidien, prévention, orientation et suivi des traitements.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
</div>
{% endblock %}
