{% extends 'base.html.twig' %}

{% block title %}Mon panier — Cabinet Martin{% endblock %}

{% block main %}
<section class="section">
  <div class="container" data-aos="fade-up">

    <div class="section-title">
      <h2>Mon panier</h2>
      <p>Verifiez vos articles avant de passer commande</p>
    </div>

    {% for label, messages in app.flashes %}
      {% for m in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'info') }} alert-dismissible fade show">
          {{ m }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
    {% endfor %}

    {% if items is empty %}
      <div class="text-center py-5">
        <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
        <h4 class="mt-3 text-muted">Votre panier est vide</h4>
        <a href="{{ path('app_pharmacie') }}" class="btn btn-primary mt-3">
          <i class="bi bi-capsule me-2"></i>Decouvrir la pharmacie
        </a>
      </div>

    {% else %}
      <div class="row g-4">

        {# --- Liste des articles --- #}
        <div class="col-lg-8">
          <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
              {% for ligne in items %}
                <div class="d-flex align-items-center p-3 border-bottom gap-3">
                  <img src="{{ asset(ligne.image) }}" alt="{{ ligne.nom }}"
                    class="rounded" style="width:80px; height:80px; object-fit:cover;">

                  <div class="flex-grow-1">
                    <h6 class="fw-bold mb-1">{{ ligne.nom }}</h6>
                    <span class="text-muted small">{{ ligne.prix }} € / unite</span>
                    {% if ligne.stock < 5 %}
                      <span class="badge bg-warning text-dark ms-2">Stock faible</span>
                    {% endif %}
                  </div>

                  <div class="d-flex align-items-center gap-1">
                    <form action="{{ path('app_panier_decrease', {id: ligne.id}) }}" method="post">
                      <button class="btn btn-sm btn-outline-secondary" type="submit">
                        <i class="bi bi-dash"></i>
                      </button>
                    </form>
                    <span class="px-3 fw-bold">{{ ligne.quantite }}</span>
                    <form action="{{ path('app_panier_add', {id: ligne.id}) }}" method="post">
                      <button class="btn btn-sm btn-outline-secondary" type="submit">
                        <i class="bi bi-plus"></i>
                      </button>
                    </form>
                  </div>

                  <div class="text-end" style="min-width: 80px;">
                    <strong>{{ (ligne.prix * ligne.quantite)|number_format(2, '.', ',') }} €</strong>
                  </div>

                  <form action="{{ path('app_panier_remove', {id: ligne.id}) }}" method="post">
                    <button class="btn btn-sm btn-outline-danger" type="submit" title="Retirer">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
              {% endfor %}
            </div>
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
              <form action="{{ path('app_panier_clear') }}" method="post">
                <button class="btn btn-sm btn-outline-danger" type="submit">
                  <i class="bi bi-trash3 me-1"></i>Vider le panier
                </button>
              </form>
              <a href="{{ path('app_pharmacie') }}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-arrow-left me-1"></i>Continuer mes achats
              </a>
            </div>
          </div>
        </div>

        {# --- Recapitulatif --- #}
        <div class="col-lg-4">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
              <h5 class="mb-0 fw-bold">Recapitulatif</h5>
            </div>
            <div class="card-body">
              {% for ligne in items %}
                <div class="d-flex justify-content-between text-muted small mb-1">
                  <span>{{ ligne.nom }} x{{ ligne.quantite }}</span>
                  <span>{{ (ligne.prix * ligne.quantite)|number_format(2, '.', ',') }} €</span>
                </div>
              {% endfor %}
              <hr>
              <div class="d-flex justify-content-between fw-bold fs-5">
                <span>Total</span>
                <span class="text-primary">{{ total|number_format(2, '.', ',') }} €</span>
              </div>
            </div>
            <div class="card-footer bg-white pt-0 border-0">
              <div class="d-grid">
                <a href="{{ path('app_paiement') }}" class="btn btn-primary btn-lg">
                  <i class="bi bi-lock me-2"></i>Passer commande
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    {% endif %}

  </div>
</section>
{% endblock %}
