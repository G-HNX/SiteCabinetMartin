{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block main %}
<style>
    .panier-container {
        max-width: 900px;
        margin: 2em auto;
        padding: 1em;
        background-color: #fdfdfd;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .panier-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #ddd;
        padding: 1em 0;
    }
    .panier-item img {
        width: 80px;
        height: auto;
        margin-right: 1em;
    }
    .panier-details {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .panier-actions {
        display: flex;
        align-items: center;
        gap: 0.5em;
    }
    .panier-actions form {
        display: inline;
    }
    .btn {
        padding: 0.4em 0.8em;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9em;
    }
    .btn-danger { background-color: #dc3545; color: white; }
    .btn-primary { background-color: #007bff; color: white; }
    .btn-outline { background-color: transparent; border: 1px solid #007bff; color: #007bff; }
    .panier-total {
        text-align: right;
        font-size: 1.2em;
        font-weight: bold;
        margin-top: 1em;
    }
    .panier-footer {
        text-align: center;
        margin-top: 2em;
    }
</style>

<div class="panier-container">
    <h1>Mon panier</h1>

    {% if items is empty %}
        <p style="text-align:center;">Votre panier est vide.</p>
    {% else %}
        {% for ligne in items %}
            <div class="panier-item">
                <img src="{{ asset(ligne.image) }}" alt="{{ ligne.nom }}">

                <div class="panier-details">
                    <strong>{{ ligne.nom }}</strong>
                    <span>Prix unitaire : {{ ligne.prix }} €</span>
                    <span>Quantité : {{ ligne.quantite }}</span>
                    <span>Total : {{ (ligne.prix * ligne.quantite)|number_format(2, '.', ',') }} €</span>
                </div>

                <div class="panier-actions">
                    <form action="{{ path('app_panier_decrease', {id: ligne.id}) }}" method="post">
                        <button class="btn btn-outline" type="submit">–</button>
                    </form>

                    <form action="{{ path('app_panier_add', {id: ligne.id}) }}" method="post">
                        <button class="btn btn-outline" type="submit">+</button>
                    </form>

                    <form action="{{ path('app_panier_remove', {id: ligne.id}) }}" method="post">
                        <button class="btn btn-danger" type="submit">Supprimer</button>
                    </form>
                </div>
            </div>
        {% endfor %}

        <div class="panier-total">
            Total général : {{ total|number_format(2, '.', ',') }} €
        </div>

        <div class="panier-footer">
            <a class="btn btn-outline" href="{{ path('app_panier_clear') }}">
                Vider le panier
            </a>

            <a href="{{ path('app_paiement') }}">
                <button class="btn btn-primary" type="button">Effectuer le paiement</button>
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}